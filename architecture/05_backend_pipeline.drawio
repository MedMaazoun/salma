        </mxCell>

        <mxCell id="x2" style="endArrow=classic;html=1;strokeColor=#9673A6;strokeWidth=2;dashed=1;" edge="1" parent="1" source="z1" target="z3" />
        <mxCell id="x2l" value="Modèles ML&#10;servis depuis Cache" style="text;fontSize=9;fontColor=#9673A6;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="730" y="345" width="170" height="30" as="geometry" />
        </mxCell>

        <mxCell id="x3" style="endArrow=classic;html=1;strokeColor=#D6B656;strokeWidth=2;dashed=1;" edge="1" parent="1" source="z3" target="z4" />
        <mxCell id="x3l" value="Données contexte&#10;envoyées au LLM" style="text;fontSize=9;fontColor=#D6B656;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="1130" y="675" width="160" height="30" as="geometry" />
        </mxCell>

        <!-- Note unités -->
        <mxCell id="note" value="Conventions d'unités systématiques (chaque endpoint a ses unités annotées dans la docstring) :&#10;durées : minutes (suffixe _min)  ·  pourcentages : 0–100 (suffixe _pct ou _rate)  ·  probabilités : 0–1 (prob, weight, importance)&#10;dates : ISO string (naïves — Europe/Paris implicite)  ·  counts : entiers (suffixe _count, n_*)  ·  effet de taille : Cohen d (sans unité) · entropie : bits" style="rounded=1;fillColor=#EFF8FF;strokeColor=#6C8EBF;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="30" y="910" width="1590" height="65" as="geometry" />
